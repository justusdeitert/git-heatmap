{
  "name": "git-heatmap",
  "version": "0.8.2",
  "description": "Interactive commit heatmap dashboard for any git repository",
  "repository": {
    "type": "git",
    "url": "https://github.com/justusdeitert/git-heatmap.git"
  },
  "type": "module",
  "bin": {
    "git-heatmap": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node --import tsx build.ts",
    "dev": "node --import tsx build.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "check": "biome check --fix . && tsc --noEmit",
    "prepublishOnly": "node --import tsx build.ts"
  },
  "keywords": [
    "git",
    "dashboard",
    "heatmap",
    "commits",
    "cli",
    "contribution-graph",
    "developer-tools"
  ],
  "author": "Justus Deitert <mail@justusdeitert.de>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "esbuild-sass-plugin": "^3.7.0",
    "sass": "^1.98.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "@preact/signals": "^2.8.2",
    "preact": "^10.29.0"
  }
}
